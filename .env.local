# Local development environment (for alembic and local dev)
DOMAIN=localhost
ENVIRONMENT=local

# CORS - allow local frontend dev servers
ALLOWED_CORS_ORIGINS=["http://localhost:4200"]

# PostgreSQL (local development)
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=test

# JWT
SECRET_KEY=super-secret-dev-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# OpenTelemetry Collector
OTLP_GRPC_ENDPOINT=http://localhost:4317
