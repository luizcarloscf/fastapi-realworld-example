# Local development environment
DOMAIN=localhost
ENVIRONMENT=local

# CORS - allow local frontend dev servers
ALLOWED_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# PostgreSQL (matches docker-compose.yaml)
DATABASE_URI=postgresql+psycopg_async://root:root@localhost:5432/test

# JWT
SECRET_KEY=super-secret-dev-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# OpenTelemetry Collector (matches docker-compose.yaml)
OTLP_GRPC_ENDPOINT=http://localhost:4317
